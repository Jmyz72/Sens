{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sens",
  "version": "0.4.5",
  "identifier": "com.sens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sens",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDRTUxM0E4Q0Q2NDVDMTcKUldRWFhHVE5xQlBsN0xPOUFMNWFBUW1NTkdJZVR1Z3RpNEw0SUc0RDhNa3VydzVxVGFDaWYyUU4K",
      "endpoints": [
        "https://github.com/Jmyz72/Sens/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
